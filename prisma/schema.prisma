generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id            String            @id @default(cuid())
  name          String
  createdAt     DateTime          @default(now())
  apps          App[]
  partners      Partner[]
  campaigns     Campaign[]
  apiKeys       ApiKey[]
  members       WorkspaceMember[]
  customDomains CustomDomain[]
  csvImports    CsvImport[]
}

model User {
  id          String            @id @default(cuid())
  email       String            @unique
  name        String?
  createdAt   DateTime          @default(now())
  memberships WorkspaceMember[]
  sessions    AuthSession[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("owner")
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model App {
  id                String      @id @default(cuid())
  workspaceId       String
  workspace         Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name              String
  bundleId          String?
  iosUrl            String
  androidUrl        String
  fallbackUrl       String
  customDomain      String?
  revenueWebhookUrl String?
  sdkStatus         String      @default("mocked")
  createdAt         DateTime    @default(now())
  smartLinks        SmartLink[]
  customDomains     CustomDomain[]
}

model Partner {
  id              String           @id @default(cuid())
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  type            String
  email           String?
  status          String           @default("active")
  createdAt       DateTime         @default(now())
  smartLinks      SmartLink[]
  payoutRules     PayoutRule[]
  payoutEstimates PayoutEstimate[]
}

model Campaign {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  channel     String
  startsAt    DateTime?
  endsAt      DateTime?
  smartLinks  SmartLink[]
}

model SmartLink {
  id              String             @id @default(cuid())
  appId           String
  app             App                @relation(fields: [appId], references: [id], onDelete: Cascade)
  slug            String             @unique
  name            String
  sourceType      String
  sourceName      String
  campaignName    String?
  campaignId      String?
  campaign        Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  partnerId       String?
  partner         Partner?           @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  iosUrl          String
  androidUrl      String
  fallbackUrl     String
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  createdAt       DateTime           @default(now())
  clicks          Click[]
  events          AttributionEvent[]
  revenueEvents   RevenueEvent[]
  payoutEstimates PayoutEstimate[]
}

model Click {
  id          String    @id @default(cuid())
  smartLinkId String
  smartLink   SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)
  timestamp   DateTime  @default(now())
  userAgent   String?
  ipHash      String?
  referrer    String?
  country     String?
  deviceType  String?
  destination String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model AttributionEvent {
  id              String    @id @default(cuid())
  smartLinkId     String
  smartLink       SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)
  eventType       String
  anonymousUserId String?
  occurredAt      DateTime  @default(now())
  metadata        String?
}

model RevenueEvent {
  id          String    @id @default(cuid())
  smartLinkId String
  smartLink   SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)
  customerId  String
  amount      Float
  currency    String    @default("USD")
  productId   String?
  source      String
  externalId  String?
  occurredAt  DateTime  @default(now())

  @@unique([source, externalId])
}

model PayoutRule {
  id                String   @id @default(cuid())
  partnerId         String
  partner           Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  ruleType          String
  commissionPercent Float?
  fixedAmount       Float?
  appliesTo         String
  createdAt         DateTime @default(now())
}

model PayoutEstimate {
  id            String    @id @default(cuid())
  partnerId     String
  partner       Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  smartLinkId   String
  smartLink     SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)
  revenueAmount Float
  payoutAmount  Float
  status        String    @default("estimated")
  createdAt     DateTime  @default(now())
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String
  prefix      String?
  scopes      String?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model CustomDomain {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  appId        String
  app          App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  hostname     String    @unique
  status       String    @default("pending")
  verification String
  createdAt    DateTime  @default(now())
  verifiedAt   DateTime?
}

model CsvImport {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  filename     String
  rowsReceived Int
  rowsAccepted Int
  rowsRejected Int
  createdAt    DateTime  @default(now())
}
